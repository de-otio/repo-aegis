#!/usr/bin/env bash
# Generated by `repo-aegis install claude-md`.
# Claude Code PostToolUse hook for Write/Edit/MultiEdit.
#
# Reads the tool-result JSON on stdin, extracts the file_path that was
# written, and runs `repo-aegis check --path` on it. The check output flows
# back into the agent's tool result; the agent reads the structured hit
# (position + engagement, redacted matchPreview) and self-corrects on the
# next turn.
#
# Critically, NEVER passes --verbose: literal markers in tool result is
# the recency-pressure failure mode the tool exists to prevent.
set -euo pipefail

if ! command -v repo-aegis >/dev/null 2>&1; then
  exit 0
fi
if ! command -v jq >/dev/null 2>&1; then
  # jq isn't strictly required; without it we silently no-op rather than
  # fail the agent's tool call.
  exit 0
fi

input=$(cat)
file_path=$(echo "$input" | jq -r '.tool_input.file_path // .tool_input.path // empty')

if [ -z "$file_path" ] || [ ! -f "$file_path" ]; then
  exit 0
fi

# Run check; surface output via the hook's stdout so the agent reads it.
repo-aegis check --path "$file_path" --json 2>&1 || true
